{
	"name": "@batterii/eslint-config-vurvey",
	"version": "1.0.3",
	"description": "Base ESLint configuration for Vurvey TypeScript projects",
	"author": "Batterii, LLC",
	"license": "MIT",
	"repository": "github:Batterii/eslint-config-vurvey",
	"files": [
		"config/",
		"legacy-config/",
		"flat/",
		"oxlint/"
	],
	"exports": {
		".": "./config/index.mjs",
		"./oxlint/.oxlintrc.json": "./oxlint/.oxlintrc.json"
	},
	"scripts": {
		"lint": "eslint .",
		"lintf": "eslint . --fix",
		"preversion": "npm run lint",
		"prepublishOnly": "git push && git push --tags"
	},
	"optionalDependencies": {
		"oxlint": "^1.57.0",
		"oxlint-tsgolint": "^0.17.3"
	},
	"peerDependencies": {
		"eslint": "^10.1.0"
	},
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-plugin-perfectionist": "^5.7.0",
		"globals": "^17.4.0",
		"typescript-eslint": "^8.57.2"
	}
}
