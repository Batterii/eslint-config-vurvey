{
	"name": "@batterii/eslint-config-vurvey",
	"version": "1.0.0",
	"description": "Base ESLint configuration for Vurvey TypeScript projects",
	"author": "Batterii, LLC",
	"license": "MIT",
	"repository": "github:Batterii/eslint-config-vurvey",
	"files": [
		"config/",
		"legacy-config/",
		"flat/",
		"oxlint/"
	],
	"exports": {
		".": "./config/index.mjs",
		"./oxlint/.oxlintrc.json": "./oxlint/.oxlintrc.json"
	},
	"scripts": {
		"lint": "eslint .",
		"lintf": "eslint . --fix",
		"preversion": "npm run lint",
		"prepublishOnly": "git push && git push --tags"
	},
	"peerDependencies": {
		"eslint": "^9.39.1"
	},
	"optionalDependencies": {
		"oxlint": "^1.31.0",
		"oxlint-tsgolint": "^0.8.3"
	},
	"dependencies": {
		"@eslint/js": "^9.39.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"typescript-eslint": "^8.48.1"
	}
}
